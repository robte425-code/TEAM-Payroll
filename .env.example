# Neon / Postgres connection string (pooling URL recommended for serverless).
# Copy to `.env` locally. In Vercel, set Environment Variables (do not commit secrets).
#
# This app reads DATABASE_URL first, then POSTGRES_URL / POSTGRES_PRISMA_URL (Neon names).
#
# Example shape (replace with your project values):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
#
DATABASE_URL=
# POSTGRES_URL=

# NextAuth + Azure AD (same sign-in pattern as teamvoc updates)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
ALLOWED_DOMAIN=team-voc.com
ADMIN_EMAILS=
