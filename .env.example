# Neon / Postgres connection string (pooling URL recommended for serverless).
# Copy to `.env` locally. In Vercel, set Environment Variables (do not commit secrets).
#
# This app reads DATABASE_URL first, then POSTGRES_URL / POSTGRES_PRISMA_URL (Neon names).
#
# Example shape (replace with your project values):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
#
DATABASE_URL=
# POSTGRES_URL=
